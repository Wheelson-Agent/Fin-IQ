{
    "preOcr": {
        "dpi": 300,
        "maxFileSizeMB": 25,
        "supportedFormats": [
            ".pdf",
            ".png",
            ".jpg",
            ".jpeg",
            ".tiff"
        ],
        "blurThreshold": 100,
        "minImageDimension": 400
    },
    "ocr": {
        "pythonPath": "python",
        "timeoutSeconds": 120,
        "retries": 3,
        "retryDelaySeconds": 5
    },
    "processing": {
        "concurrentWorkers": 5,
        "batchSize": 10
    },
    "paths": {
        "unprocessed": "./data/unprocessed",
        "processed": "./data/processed",
        "backup": "./data/backup"
    },
    "auth": {
        "sessionExpiryHours": 24,
        "maxLoginAttempts": 5
    }
}